require(data.table)
# require(R.utils)
require(dplyr)
require(tidyr)
# require(tidyverse)
require(stringr)
# require(rstudioapi)
# setwd(dirname(rstudioapi::getActiveDocumentContext()$path))
# dstrace("", direction = 'both', graph = TRUE)
# dstrace_chunks('module_gcamchina_L2235.elec_segments_GRID', gcam_data_map)
# Specify the path to the folder you want to search
# Use "." to search the current working directory
# folder_path <-"F:/0_HKU_work/2_GCAM/GCAM_82_Global/gcam-china-v6-Windows-Release-Package/input/gcamdata/R/"  # "F:/0_HKU_work/2_GCAM/gcam-china-v7.1-Windows-Release-Package/input/gcamdata/R/" # "F:/0_HKU_work/2_GCAM/GCAM_82_Global/gcam-china-v7.1-Windows-Release-Package/input/gcamdata/R/" # 'F:\\0_HKU_work\\2_GCAM\\GCAM_82_Global\\gcam-v8.2-Windows-Release-Package\\input\\gcamdata\\R\\' #
# folder_path <-"F:/0_HKU_work/2_GCAM/GCAM_sea/gcamv5p3_seasia/input/gcamdata/R/"
folder_path <-"E:/0_HKU_work/2_GCAM/GCAM_china/gcam-china-v7-Windows-Release-Package/input/gcamdata/R/"
# folder_path <-"F:/0_HKU_work/2_GCAM/GCAM_82_Global/gcam-v7.1-Windows-Release-Package/input/gcamdata/R/"
# Get a list of all .R files in the specified folder and its subdirectories
all_files <- list.files(path = folder_path, pattern = "\\.R$", recursive = TRUE, full.names = TRUE)
# data.table::fwrite(data.frame(Rcode = gsub(folder_path, '', all_files)),
#                    'F:/0_HKU_work/2_GCAM/gcam-china-v7.1-Windows-Release-Package/input/gcamdata/Rcodelist.csv')
# Define the text pattern to search for
search_pattern <- 'gcam-china/cR_BldS_F_U_share' # 'L101.NBS_use_all_Mtce' # 'L101.inNBS_Mtce_province_S_F' # 'Total Transformation' # 'TPES' # 'base load generation' # 'gcamchina.BASE_HDD_CHINA' # 'gcamchina.PROVINCES_ALL' # 'gcamchina.PROVINCES_NOHKMC'
# Loop through each file and check for the search pattern
fileline.list <- data.table()
for (file in all_files) {
# Read all lines from the file
lines <- readLines(file, warn = FALSE)
# Search for the pattern within the lines
# The 'grep' function returns the line numbers that contain a match
matching_lines <- grep(search_pattern, lines, value = FALSE)
# If any matches are found, print the file name and the line numbers
if (length(matching_lines) > 0) {
cat("Found a match in file:", file, "\n")
cat("On lines:", matching_lines, "\n\n")
fileline.list <- rbind(fileline.list,
data.table(file = gsub(folder_path, "", file)))
}
}
fileline.list
search_pattern <- 'gcam-china/cR_BldS_F_U_share' # 'L101.NBS_use_all_Mtce' # 'L101.inNBS_Mtce_province_S_F' # 'Total Transformation' # 'TPES' # 'base load generation' # 'gcamchina.BASE_HDD_CHINA' # 'gcamchina.PROVINCES_ALL' # 'gcamchina.PROVINCES_NOHKMC'
# Loop through each file and check for the search pattern
fileline.list <- data.table()
for (file in all_files) {
# Read all lines from the file
lines <- readLines(file, warn = FALSE)
# Search for the pattern within the lines
# The 'grep' function returns the line numbers that contain a match
matching_lines <- grep(search_pattern, lines, value = FALSE)
# If any matches are found, print the file name and the line numbers
if (length(matching_lines) > 0) {
cat("Found a match in file:", file, "\n")
cat("On lines:", matching_lines, "\n\n")
fileline.list <- rbind(fileline.list,
data.table(file = gsub(folder_path, "", file)))
}
}
