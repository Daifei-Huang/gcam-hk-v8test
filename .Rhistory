# 设置颜色主题 (如果原图是自定义颜色，可以使用 scale_fill_manual(values = c(...)) )
scale_fill_viridis_d(option = "turbo") +
# 使用简洁的学术主题
theme_minimal(base_size = 14) +
# 设置图表标题和坐标轴标签
labs(
