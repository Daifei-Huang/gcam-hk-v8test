    <region name="HK">
      <!-- HK building-envelope scenario: moderate; lower shell-conductance means lower envelope heat transfer. -->
      <!-- Values are explicit five-year GCAM periods from 2025 to 2100; no rural consumers; residential deciles share one trajectory. -->
