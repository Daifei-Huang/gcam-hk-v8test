<?xml version="1.0" encoding="UTF-8"?>
<scenario>
  <world>
    <region name="HK">

        <!-- company with 2025 policy constraints for coal generation -->
        <!-- since the olad vintage coal-fired power units are not enough to support 2025 coal generation in GCAM default settings (we don't want to change the retirement curve of the existing vintage), -->
        <!-- so we make pseudo new coal in 2025 to fill the gap -->
        <!-- The existing coal-fired power plants' retirement schedule in L2231 has led to a rapid decline in coal-fired power generation in 2025; however, the actual coal-fired power generation in Hong Kong from 2021 to 2024 remained relatively stable. -->
        
        <pass-through-sector name="base load generation">
            <subsector name="coal">
                <stub-technology name="coal_base_conv pul">
                    <period year="2025">
                        <share-weight>1</share-weight>
                    </period>
                    <lifetime>15</lifetime>
                    <s-curve-shutdown-decider name="s-curve">
                        <steepness>0.3</steepness> 
                        <half-life>9</half-life>
                    </s-curve-shutdown-decider>
                    <interpolation-rule apply-to="share-weight" from-year="2030" to-year="2100" delete="1">
                        <from-value>0</from-value><to-value>0</to-value>
                        <interpolation-function name="fixed" />
                    </interpolation-rule>
                    <period year="2030">
                        <share-weight>0</share-weight>
                    </period>
                    <period year="2100">
                        <share-weight>0</share-weight>
                    </period>
                    <interpolation-rule apply-to="share-weight" from-year="2030" to-year="2100">
                        <from-value>0</from-value><to-value>0</to-value>
                        <interpolation-function name="fixed" />
                    </interpolation-rule>
                </stub-technology>
                <stub-technology name="coal_base_conv pul_CCS">
                    <period year="2025">
                        <share-weight>1</share-weight>
                    </period>
