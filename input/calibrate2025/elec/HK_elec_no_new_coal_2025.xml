<scenario>
  <world>
    <region name="HK">

        <!-- refer to https://github.com/JGCRI/seasia/blob/main/modeling/malaysia/sectoral_policies/elec_no_new_coal.xml -->
        <!-- Actually, Hong Kong stopped to build coal plants or to introduce new coal-fired unit since 1997. -->
        <!-- Since the base year is 2021 (share-weight in subsector level cannot be reset in base year, and the coal_*_conv pul technology share-weight in 2021 is already 0), to simulate this case, we set the share-weight since 2025 zero -->
        <!-- which means the increment was zero since 2021 -->
        <!-- v8 有 Coal vintage，在构造模型输入数据时，即有香港在 2021 年的 <stub-technology name="coal_base_conv pul"> 的 share-weight 为 0, 2021 年的 coal calOutput 完全依赖 coal_base_conv pul 1996-2000、coal_base_conv pul 1991-1995、coal_base_conv pul before 1990 -->
        <!-- HK_elec_no_new_coal_2025.xml 构造了香港 2025年起的所有煤电技术 share-weight 为0，意味着没有新增的煤电机组，因此 2021年起 香港煤电完全依赖 coal_base_conv pul 1996-2000、coal_base_conv pul 1991-1995、coal_base_conv pul before 1990 -->

        <pass-through-sector name="base load generation">
            <subsector name="coal">
                <stub-technology name="coal_base_conv pul">
                    <period year="2025">
                        <share-weight>0</share-weight>
                    </period>
                    <period year="2100">
                        <share-weight>0</share-weight>
                    </period>
                    <interpolation-rule apply-to="share-weight" from-year="2025" to-year="2100" delete="1">
                        <from-value>0</from-value><to-value>0</to-value>
                        <interpolation-function name="fixed" />
                    </interpolation-rule>
                    <period year="2025">
                        <share-weight>0</share-weight>
                    </period>
                    <period year="2100">
                        <share-weight>0</share-weight>
                    </period>
                    <interpolation-rule apply-to="share-weight" from-year="2025" to-year="2100">
                        <from-value>0</from-value><to-value>0</to-value>
                        <interpolation-function name="fixed" />
                    </interpolation-rule>
                </stub-technology>
                <stub-technology name="coal_base_conv pul_CCS">
                    <period year="2025">
                        <share-weight>0</share-weight>
                    </period>
                    <period year="2100">
                        <share-weight>0</share-weight>
                    </period>
                    <interpolation-rule apply-to="share-weight" from-year="2025" to-year="2100" delete="1">
                        <from-value>0</from-value><to-value>0</to-value>
                        <interpolation-function name="fixed" />
                    </interpolation-rule>
                    <period year="2025">
                        <share-weight>0</share-weight>
                    </period>
                    <period year="2100">
                        <share-weight>0</share-weight>
                    </period>
                    <interpolation-rule apply-to="share-weight" from-year="2025" to-year="2100">
                        <from-value>0</from-value><to-value>0</to-value>
                        <interpolation-function name="fixed" />
                    </interpolation-rule>
                </stub-technology>
                <stub-technology name="coal_base_IGCC">
                <period year="2025">
                    <share-weight>0</share-weight>
                </period>
                    <period year="2100">
                        <share-weight>0</share-weight>
                    </period>
                <interpolation-rule apply-to="share-weight" from-year="2025" to-year="2100" delete="1">
                        <from-value>0</from-value><to-value>0</to-value>
                        <interpolation-function name="fixed" />
                </interpolation-rule>
                <period year="2025">
                    <share-weight>0</share-weight>
                </period>
                    <period year="2100">
                        <share-weight>0</share-weight>
                    </period>
                <interpolation-rule apply-to="share-weight" from-year="2025" to-year="2100">
                        <from-value>0</from-value><to-value>0</to-value>
                        <interpolation-function name="fixed" />
                </interpolation-rule>
                </stub-technology>
                <stub-technology name="coal_base_IGCC_CCS">
                    <period year="2025">
                            <share-weight>0</share-weight>
                        </period>
                        <period year="2100">
                            <share-weight>0</share-weight>
                        </period>
                        <interpolation-rule apply-to="share-weight" from-year="2025" to-year="2100" delete="1">
                            <from-value>0</from-value><to-value>0</to-value>
                            <interpolation-function name="fixed" />
                        </interpolation-rule>
                        <period year="2025">
                            <share-weight>0</share-weight>
                        </period>
                        <period year="2100">
                            <share-weight>0</share-weight>
                        </period>
                        <interpolation-rule apply-to="share-weight" from-year="2025" to-year="2100">
                            <from-value>0</from-value><to-value>0</to-value>
                            <interpolation-function name="fixed" />
                        </interpolation-rule>
                </stub-technology>
            </subsector>
        </pass-through-sector>

